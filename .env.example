# OE Picks — env template. Copy to .env.local and fill with real values.
# .env.local is gitignored. NEVER put real secrets in this .example file.
# Server-side only (never the client bundle): ANTHROPIC, SERVICE_ROLE, all odds/stats keys.

# --- AI ---
ANTHROPIC_API_KEY=          # Edge Function secret. https://console.anthropic.com

# --- Supabase ---
SUPABASE_URL=               # https://app.supabase.com -> Project Settings -> API
SUPABASE_ANON_KEY=          # client-safe
SUPABASE_SERVICE_ROLE_KEY=  # server-side only

# --- Odds / lines ---
THE_ODDS_API_KEY=           # https://the-odds-api.com
SHARP_API_KEY=              # optional. https://sharpapi.com

# --- Stats / box scores ---
BALLDONTLIE_API_KEY=        # https://app.balldontlie.io
API_SPORTS_KEY=             # https://api-sports.io

# --- Internal services ---
MODEL_SERVICE_URL=          # http://localhost:8000 locally; Render/Railway URL in prod
